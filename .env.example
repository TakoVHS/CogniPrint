# CogniPrint optional billing layer — local test-mode example
# Never commit real secrets. Use test placeholders only.

ENVIRONMENT=development
APP_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=sqlite:///./cogniprint_dev.db

FREE_DAILY_SCAN_LIMIT=3
MAX_TEXT_CHARS_FREE=12000
MAX_TEXT_CHARS_PRO=120000

BILLING_ENABLED=true
BILLING_MODE=test

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_RESEARCH_PRO=price_research_pro_placeholder
STRIPE_SUCCESS_URL=http://localhost:5173/billing-success.html
STRIPE_CANCEL_URL=http://localhost:5173/billing-cancel.html
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:5173/account.html
