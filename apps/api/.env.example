# CogniPrint Content Scanner API — Environment Variables
# Copy this file to .env for local development.
# In Railway, set these variables via the Railway dashboard (never commit real values).

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
# Railway Postgres plugin injects this automatically.
# For local dev, omit to use the SQLite fallback.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Stripe ────────────────────────────────────────────────────────────────────
# Obtain from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Obtain from Stripe Dashboard → Developers → Webhooks → endpoint secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Obtain from Stripe Dashboard → Products → CogniPrint Pro → Price ID
STRIPE_PRO_PRICE_ID=price_...

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Must match the exact origin of the Vercel frontend (no trailing slash).
FRONTEND_URL=https://scanner.cogniprint.ai

# ── Scan limits ───────────────────────────────────────────────────────────────
FREE_DAILY_SCAN_LIMIT=3
MAX_TEXT_CHARS_FREE=12000
MAX_TEXT_CHARS_PRO=120000
